---
machine:
  install:
    disk: /dev/sda
    wipe: true # Indicates if the installation disk should be wiped at installation time.
  type: controlplane
  nodeTaints:
    node-role.kubernetes.io/control-plane: :NoSchedule
  network:
    hostname: cp03
    interfaces:
      - addresses:
          - 10.0.60.203/24
        interface: ens18
        dhcp: false
        mtu: 1500
        routes:
          - gateway: 10.0.60.1
            network: 0.0.0.0/0
