    interfaces:
      - addresses:
          - 10.0.60.205/24
        interface: ens18
        dhcp: false
        mtu: 1500
        routes:
          - gateway: 10.0.60.1
            network: 0.0.0.0/0
            metric: 100
      - addresses:
          - 10.0.69.205/24
        interface: ens19
        dhcp: false
